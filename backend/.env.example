# Copy this file to .env and fill in your own values.
# Never commit the actual .env file — it's already in .gitignore.

# Port the Express server runs on
PORT=5000

# MongoDB Atlas connection string
# Get this from: Atlas Dashboard -> Database -> Connect -> Drivers
# Format: mongodb+srv://<username>:<password>@<cluster-url>/<database-name>
MONGO_URI=mongodb+srv://your_username:your_password@your-cluster.mongodb.net/bite-rush

# Secret key used to sign JWT auth tokens — use a long, random, unique string
# Generate one with: openssl rand -base64 48
JWT_SECRET=replace_this_with_a_long_random_secret
